<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="30.0.4">
  <diagram name="方案B-TaskShape统一配置轴">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="2" value="&lt;b style=&quot;font-size:18px&quot;&gt;方案 B：TaskShape 统一配置轴&lt;/b&gt;&#xa;&#xa;核心抽象：一个任务形态，同时驱动「验证策略」和「审查策略」两个正交关注点——避免两个独立配置轴互相引用" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1100" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 顶层：TaskShape 统一配置轴（突出显示）===== -->
        <mxCell id="100" value="&lt;b style=&quot;font-size:15px;color:#fff&quot;&gt;TaskShape（统一配置轴）&lt;/b&gt;&#xa;&#xa;&lt;span style=&quot;color:#f0f0f0&quot;&gt;一个任务形态 = 验证策略 ⊕ 审查策略 的组合&lt;br/&gt;在 create / clarify 时确定，向下同时驱动两个策略&lt;br/&gt;现有 TDD 全链只是众多 TaskShape 之一，不再是默认/唯一路径&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#111827;fontColor=#ffffff;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="75" width="700" height="95" as="geometry" />
        </mxCell>

        <!-- TaskShape 向下分叉箭头（到两个策略） -->
        <mxCell id="110" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#1f2937;strokeWidth=2;" edge="1" parent="1" source="100" target="200">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="111" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#1f2937;strokeWidth=2;" edge="1" parent="1" source="100" target="300">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== 中层左：VerificationStrategy 接口 ===== -->
        <mxCell id="200" value="&lt;b style=&quot;font-size:13px&quot;&gt;VerificationStrategy（验证策略）&lt;/b&gt;&#xa;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;关注点：dev 前后「做什么检查」证明任务做对了&lt;/font&gt;&#xa;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;preDevCheck(topic, payload)   // dev 前（替代 tdd_plan）&lt;/span&gt;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;postDevVerify(topic)          // dev 后（替代 test）&lt;/span&gt;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;replanGuard(old, next)        // 安全守卫&lt;/span&gt;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;isDevVerified(topic)          // gate 判定&lt;/span&gt;&#xa;&#xa;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;实现：tdd / existence / regression / review-only&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=middle;spacingLeft=15;spacingRight=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="500" height="175" as="geometry" />
        </mxCell>

        <!-- ===== 中层右：ReviewStagePolicy 接口 ===== -->
        <mxCell id="300" value="&lt;b style=&quot;font-size:13px&quot;&gt;ReviewStagePolicy（审查策略）&lt;/b&gt;&#xa;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;关注点：「走哪几段 review」+「用哪些审查维度」&lt;/font&gt;&#xa;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;stages: ReviewStage[]          // 阶段序列裁剪&lt;/span&gt;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;  &amp;gt; spec_review? plan_review? review?&lt;/span&gt;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;dimensions: ReviewDimension[]  // 审查维度子集&lt;/span&gt;&#xa;&lt;span style=&quot;font-family:monospace;font-size:10px&quot;&gt;  &amp;gt; type-safety? test-coverage? ...&lt;/span&gt;&#xa;&#xa;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;实现：full-review / lean-review / doc-review / skip&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=middle;spacingLeft=15;spacingRight=15;" vertex="1" parent="1">
          <mxGeometry x="620" y="210" width="500" height="175" as="geometry" />
        </mxCell>

        <!-- 两个策略正交说明（中间连接线 + 注释） -->
        <mxCell id="250" value="正交但相关&#xa;（由同一 TaskShape 组合）" style="endArrow=classic;startArrow=classic;html=1;rounded=0;dashed=1;strokeColor=#9673a6;fontSize=9;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="200" target="300">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== 流程编排层（通用，带介入点）===== -->
        <mxCell id="400" value="流程编排层（通用，所有任务必走的状态流转）" style="swimlane;startSize=24;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=11;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1100" height="200" as="geometry" />
        </mxCell>

        <!-- 流程节点行（create → clarify → spec_review → plan → plan_review → dev前验证 → dev → dev后验证 → review → retrospect → closeout） -->
        <mxCell id="410" value="create" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="400">
          <mxGeometry x="20" y="40" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="411" value="clarify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="400">
          <mxGeometry x="115" y="40" width="80" height="40" as="geometry" />
        </mxCell>
        <!-- spec_review（审查阶段，可裁剪） -->
        <mxCell id="412" value="spec_review&#xa;[审查]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=2;" vertex="1" parent="400">
          <mxGeometry x="210" y="40" width="85" height="40" as="geometry" />
        </mxCell>
        <mxCell id="413" value="plan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="400">
          <mxGeometry x="310" y="40" width="70" height="40" as="geometry" />
        </mxCell>
        <!-- plan_review（审查阶段，可裁剪） -->
        <mxCell id="414" value="plan_review&#xa;[审查]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=2;" vertex="1" parent="400">
          <mxGeometry x="395" y="40" width="85" height="40" as="geometry" />
        </mxCell>
        <!-- dev 前验证（菱形，验证注入点） -->
        <mxCell id="415" value="◆ dev前&#xa;验证" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="400">
          <mxGeometry x="495" y="33" width="85" height="55" as="geometry" />
        </mxCell>
        <mxCell id="416" value="dev" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="400">
          <mxGeometry x="595" y="40" width="60" height="40" as="geometry" />
        </mxCell>
        <!-- dev 后验证（菱形，验证注入点） -->
        <mxCell id="417" value="◆ dev后&#xa;验证" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="400">
          <mxGeometry x="670" y="33" width="85" height="55" as="geometry" />
        </mxCell>
        <!-- review（审查阶段，可裁剪维度） -->
        <mxCell id="418" value="review&#xa;[审查]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=2;" vertex="1" parent="400">
          <mxGeometry x="770" y="40" width="70" height="40" as="geometry" />
        </mxCell>
        <mxCell id="419" value="retrospect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="400">
          <mxGeometry x="855" y="40" width="85" height="40" as="geometry" />
        </mxCell>
        <mxCell id="420" value="closeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="400">
          <mxGeometry x="955" y="40" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- 流程箭头 -->
        <mxCell id="430" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#999;" edge="1" parent="400" source="410" target="411"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="431" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#999;" edge="1" parent="400" source="411" target="412"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="432" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#999;" edge="1" parent="400" source="412" target="413"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="433" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#999;" edge="1" parent="400" source="413" target="414"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="434" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor:#82b366;" edge="1" parent="400" source="414" target="415"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="435" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor:#82b366;" edge="1" parent="400" source="415" target="416"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="436" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor:#82b366;" edge="1" parent="400" source="416" target="417"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="437" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor:#d6b656;" edge="1" parent="400" source="417" target="418"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="438" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#999;" edge="1" parent="400" source="418" target="419"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="439" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#999;" edge="1" parent="400" source="419" target="420"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 介入点说明（第二行） -->
        <mxCell id="450" value="&lt;b&gt;介入点说明：&lt;/b&gt;&#xa;&lt;span style=&quot;color:#82b366&quot;&gt;◆ 绿色菱形&lt;/span&gt; = 验证注入点（VerificationStrategy 决定做什么检查，可能为空）&#xa;&lt;span style=&quot;color:#d6b656&quot;&gt;[审查] 黄色&lt;/span&gt; = 审查阶段（ReviewStagePolicy 决定是否走 + 用什么维度）&#xa;&lt;span style=&quot;color:#6c8ebf&quot;&gt;蓝色&lt;/span&gt; = 通用流程节点（所有任务必走，不变）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#e0e0e0;fontSize=10;spacingLeft=10;spacingRight=10;" vertex="1" parent="400">
          <mxGeometry x="20" y="110" width="1040" height="70" as="geometry" />
        </mxCell>

        <!-- 策略 → 介入点的虚线（表示驱动关系） -->
        <!-- VerificationStrategy → dev前/dev后验证 -->
        <mxCell id="460" value="驱动" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeColor=#82b366;fontSize=9;fontStyle=2;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="200" target="400">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ReviewStagePolicy → 审查阶段 -->
        <mxCell id="461" value="驱动" style="endArrow=classic;html=1;rounded=0;dashed=1;strokeColor=#d6b656;fontSize=9;fontStyle=2;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="300" target="400">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== 底层：4 种 TaskShape 实例（组合表）===== -->
        <mxCell id="500" value="4 种内置 TaskShape 实例（验证策略 ⊕ 审查策略 的预设组合）" style="swimlane;startSize=24;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=11;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="1100" height="250" as="geometry" />
        </mxCell>

        <!-- full-tdd -->
        <mxCell id="510" value="&lt;b style=&quot;font-size:12px&quot;&gt;full-tdd&lt;/b&gt;&#xa;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;（现有全链，不变）&lt;/font&gt;&#xa;&#xa;&lt;b&gt;验证：&lt;/b&gt;&lt;span style=&quot;color:#d79b00&quot;&gt;tdd&lt;/span&gt;&#xa;  test.json+红灯→转绿&#xa;&#xa;&lt;b&gt;审查：&lt;/b&gt;&lt;span style=&quot;color:#9673a6&quot;&gt;full-review&lt;/span&gt;&#xa;  spec+plan+review 全段&#xa;  全 6 维度&#xa;&#xa;&lt;b&gt;适用：&lt;/b&gt;新功能/Bug修复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=10;" vertex="1" parent="500">
          <mxGeometry x="20" y="40" width="250" height="195" as="geometry" />
        </mxCell>

        <!-- delete-only -->
        <mxCell id="511" value="&lt;b style=&quot;font-size:12px&quot;&gt;delete-only&lt;/b&gt;&#xa;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;（新增）&lt;/font&gt;&#xa;&#xa;&lt;b&gt;验证：&lt;/b&gt;&lt;span style=&quot;color:#82b366&quot;&gt;existence&lt;/span&gt;&#xa;  产物清单→存在性检查&#xa;&#xa;&lt;b&gt;审查：&lt;/b&gt;&lt;span style=&quot;color:#9673a6&quot;&gt;lean-review&lt;/span&gt;&#xa;  跳 spec/plan review&#xa;  design+edge-case 维度&#xa;&#xa;&lt;b&gt;适用：&lt;/b&gt;纯删除/死代码清理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=10;" vertex="1" parent="500">
          <mxGeometry x="290" y="40" width="250" height="195" as="geometry" />
        </mxCell>

        <!-- refactor -->
        <mxCell id="512" value="&lt;b style=&quot;font-size:12px&quot;&gt;refactor&lt;/b&gt;&#xa;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;（新增）&lt;/font&gt;&#xa;&#xa;&lt;b&gt;验证：&lt;/b&gt;&lt;span style=&quot;color:#82b366&quot;&gt;regression&lt;/span&gt;&#xa;  跳红灯，既有测试全绿&#xa;&#xa;&lt;b&gt;审查：&lt;/b&gt;&lt;span style=&quot;color:#9673a6&quot;&gt;lean-review&lt;/span&gt;&#xa;  跳 spec review&#xa;  含 test-coverage 维度&#xa;&#xa;&lt;b&gt;适用：&lt;/b&gt;行为不变的重构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=10;" vertex="1" parent="500">
          <mxGeometry x="560" y="40" width="250" height="195" as="geometry" />
        </mxCell>

        <!-- doc-only -->
        <mxCell id="513" value="&lt;b style=&quot;font-size:12px&quot;&gt;doc-only&lt;/b&gt;&#xa;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;（新增）&lt;/font&gt;&#xa;&#xa;&lt;b&gt;验证：&lt;/b&gt;&lt;span style=&quot;color:#82b366&quot;&gt;review-only&lt;/span&gt;&#xa;  无机器验证，review 兜底&#xa;&#xa;&lt;b&gt;审查：&lt;/b&gt;&lt;span style=&quot;color:#9673a6&quot;&gt;doc-review&lt;/span&gt;&#xa;  跳 spec/plan review&#xa;  仅 design-consistency 维度&#xa;&#xa;&lt;b&gt;适用：&lt;/b&gt;文档/配置/架构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=10;" vertex="1" parent="500">
          <mxGeometry x="830" y="40" width="250" height="195" as="geometry" />
        </mxCell>

        <!-- 底部：为什么统一轴的说明 -->
        <mxCell id="600" value="&lt;b style=&quot;font-size:12px&quot;&gt;为什么是统一 TaskShape 轴，而不是两个独立配置？&lt;/b&gt;&#xa;&#xa;&lt;b&gt;因为验证策略与审查策略是相关的，不是完全独立：&lt;/b&gt;&#xa;• 「是否需要 test-coverage 审查维度」本质上由验证策略决定——非 TDD 任务（existence/regression 策略）不需要 test-coverage review&#xa;• 如果做成两个独立配置轴（verificationStrategy + reviewStagePolicy 各自独立选择），会出现「选了 review-only 验证却保留了 test-coverage 审查」这类不自洽组合，需要额外校验两者一致&#xa;&#xa;&lt;b&gt;统一成 TaskShape 的好处：&lt;/b&gt;&#xa;• 一个任务形态 = 一个预设的组合，agent 只需识别任务性质选 shape，不用分别配置两个策略&#xa;• 组合的合法性在 shape 定义时保证，运行时不会出现不自洽&#xa;• 新增任务类型只需定义一个 TaskShape（声明它用哪个验证 ⊕ 哪个审查），不用动状态机" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fc;strokeColor=#6c8ebf;align=left;verticalAlign=middle;spacingLeft=16;spacingRight=16;spacingTop=10;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="930" width="1100" height="140" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
